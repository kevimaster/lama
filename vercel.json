{
  "version": 2,
  "buildCommand": "node scripts/build-vercel.js",
  "outputDirectory": "_site",
  "routes": [
    { "src": "/simuladores/el-sesgo-invisible/(.*)", "dest": "/simuladores/el-sesgo-invisible/$1" },
    { "src": "/simuladores/(.*)/", "dest": "/simuladores/$1/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
